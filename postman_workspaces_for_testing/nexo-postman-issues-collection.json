{
  "info": {
    "name": "Nexo Issues Flows",
    "description": "Postman collection for testing Issue endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Issue",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.id) {",
              "    pm.collectionVariables.set(\"issueId\", jsonData.id);",
              "    console.log(\"Saved issueId to collection variables!\");",
              "} else {",
              "    console.log(\"Issue ID not found in response!\");",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/issues",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "issues"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Implement login page\",\n  \"description\": \"Create a responsive login page using React.\",\n  \"acceptanceCriteria\": \"User can login with email and password.\",\n  \"reporterId\": 1,\n  \"assigneeId\": 1,\n  \"storyPoints\": 5,\n  \"priority\": \"HIGH\",\n  \"type\": \"TASK\",\n  \"startDate\": \"2023-10-26T10:00:00\",\n  \"deadline\": \"2023-11-02T18:00:00\",\n  \"boardId\": 1,\n  \"stageId\": 1,\n  \"organizationId\": 1\n}"
        }
      }
    },
    {
      "name": "2. Get Issues",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/issues",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "issues"
          ]
        }
      }
    },
    {
      "name": "3. Get Issues by Organization",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/issues?organizationId=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "issues"
          ],
          "query": [
            {
              "key": "organizationId",
              "value": "1"
            }
          ]
        }
      }
    },
    {
      "name": "4. Get Issue by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/issues/{{issueId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "issues",
            "{{issueId}}"
          ]
        }
      }
    },
    {
      "name": "5. Update Issue",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/issues/{{issueId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "issues",
            "{{issueId}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Implement login page updated\",\n  \"description\": \"Updated description\",\n  \"storyPoints\": 8,\n  \"priority\": \"HIGHEST\",\n  \"flag\": true,\n  \"type\": \"STORY\"\n}"
        }
      }
    },
    {
      "name": "6. Delete Issue",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/issues/{{issueId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "issues",
            "{{issueId}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "issueId",
      "value": "",
      "type": "string"
    }
  ]
}